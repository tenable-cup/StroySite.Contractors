<Page x:Class="StroySite.WPF.ContractorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Контрагенты"
      Loaded="Page_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель поиска -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBox x:Name="txtSearch" Width="200" Margin="5" Height="29"/>
            <Button x:Name="btnSearch" Content="Найти" Width="80" Margin="5" Click="btnSearch_Click"/>
            <Button x:Name="btnRefresh" Content="Обновить" Width="110" Margin="5" Click="btnRefresh_Click"/>
        </StackPanel>

        <!-- Таблица контрагентов -->
        <DataGrid x:Name="dgContractors" 
                  Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding FullName}" Width="200"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="200"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding ContractorsType.TypeName}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки действий -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnAdd" Content="Добавить" Width="100" Margin="5" Click="btnAdd_Click"/>
            <Button x:Name="btnEdit" Content="Изменить" Width="100" Margin="5" Click="btnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Margin="5" Click="btnDelete_Click"/>
        </StackPanel>
    </Grid>
</Page>